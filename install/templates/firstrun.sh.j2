#!/bin/sh
set -e

## USER_SETUP
## ssh keys for passwordless login
echo "Adding ssh public keys for passwordless logins..."
sudo mkdir -p /home/{{ ansible_user }}/.ssh
sudo sh -c 'cat << EOF > /home/{{ ansible_user }}/.ssh/authorized_keys
ssh-rsa  nicola@avm
ssh-rsa 
ssh-rsa  christian@shf-nb-164
ssh-rsa  mathias@SHF-NB-196
ssh-rsa  daniel@Ubuntu-ThinkPad
ssh-rsa  felix@avm-notebook-felix
ssh-rsa  shai@dune
EOF'
sudo chown -R {{ ansible_user }}:users /home/{{ ansible_user }}/.ssh
sudo chmod 700 /home/{{ ansible_user }}/.ssh
sudo chmod 600 /home/{{ ansible_user }}/.ssh/authorized_keys
##################

## END USER SETUP ##############################################################



# Check if installation takes place  in .asg network and set proxy accordingly
if hostname -I | grep -qE '172.25.1[6789]' ; then
  echo "We are in .asg network, will setup proxy now"avm
  sudo sh -c 'cat << EOF > /etc/apt/apt.conf.d/95proxies
Acquire::http::Proxy "http://172.16.10.122:8888";
Acquire::https::Proxy "http://172.16.10.122:8888";
EOF'
# Systemwide for now
export http_proxy=http://172.16.10.122:8888
export https_proxy=http://172.16.10.122:8888
fi

##################
## END SOFTWARE SETUP ##########################################################

## SYSTEM SETTINGS #############################################################
## Set ntp server
echo "Setting timeserver"
sudo sh -c 'echo "NTP=192.168.144.11" >> /etc/systemd/timesyncd.conf'
sudo systemctl restart systemd-timesyncd.service
##################


## Load Dell HW Monitoring kernel module at boot time (late)
sudo sh -c 'echo "options dell-smm-hwmon force=1" > /etc/modprobe.d/dell-smm-hwmon.conf'
sudo sh -c 'echo "dell-smm-hwmon" > /etc/modules-load.d/dell-smm-hwmon.conf'
##################


# Setting GRUB timeout to 0
echo "Setting Grub timeout to 0..."
sudo sed -i "/GRUB_TIMEOUT=/c\GRUB_TIMEOUT=0" /etc/default/grub
sudo update-grub
##################

# WOL-Fix for dreaded Optiplex Hardware
sudo sh -c 'interface=$(ip route show default | awk '\''/default/ {print $5}'\'') ; cat << EOF > /etc/systemd/system/wolfix.service
[Unit]
Description=Fix Wake on LAN reboot problem
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/sbin/ethtool -s $interface wol g

[Install]
WantedBy=multi-user.target
EOF'
sudo systemctl daemon-reload
sudo systemctl enable wolfix
##################

## Install system MQTT probe and services #####
cd /home/{{ ansible_user }}
sudo tar --no-overwrite-dir -xvf /home/{{ ansible_user }}/probe_installer.tar.gz
cd /home/{{ ansible_user }}/probe_installer/humboldt_probe
sudo mkdir -p /home/{{ ansible_user }}/humboldt_probe
APP_PY=/home/{{ ansible_user }}/humboldt_probe/src/app.py
CONFIG_FILE=/home/{{ ansible_user }}/content/userconfig.txt
MQTT_HOSTNAME=srv-control-avm
CA_CERTIFICATE=/home/{{ ansible_user }}/humboldt_probe/tls/ca_certificate.pem
CERTFILE=/home/{{ ansible_user }}/humboldt_probe/tls/client_certificate.pem
KEYFILE=/home/{{ ansible_user }}/humboldt_probe/tls/client_key.pem
LOGLEVEL=CRITICAL

sudo cp -r ./src /home/{{ ansible_user }}/humboldt_probe
sudo cp -r ./tls /home/{{ ansible_user }}/humboldt_probe
sudo chown -R {{ ansible_user }}:users /home/{{ ansible_user }}/humboldt_probe
sudo chmod -R 0600 /home/{{ ansible_user }}/humboldt_probe
sudo chmod 0700 /home/{{ ansible_user }}/humboldt_probe
sudo chmod 0700 /home/{{ ansible_user }}/humboldt_probe/tls
sudo chmod 0700 /home/{{ ansible_user }}/humboldt_probe/src
sudo chmod 0700 /home/{{ ansible_user }}/humboldt_probe/src/methods
sudo chmod 0700 /home/{{ ansible_user }}/humboldt_probe/src/misc

render_template() {
  eval "echo \"$(cat $1)\""
}

render_template humboldt-probe.service.template | sudo tee /etc/systemd/system/humboldt-probe.service


## Install python sd-notify
cd /home/{{ ansible_user }}/probe_installer/sd-notify-0.1.0
sudo python3 setup.py install
cd ../
sudo rm -rf /home/{{ ansible_user }}/probe_installer/sd-notify-0.1.0

sudo systemctl daemon-reload
sudo systemctl enable humboldt-probe.service

#Config-file
chmod +x /home/{{ ansible_user }}/probe_installer/patch_userconfig.py
sudo /home/{{ ansible_user }}/probe_installer/patch_userconfig.py /home/{{ ansible_user }}/content/userconfig.txt
sudo chown {{ ansible_user }}:users /home/{{ ansible_user }}/content/userconfig.txt
sudo chmod 665 /home/{{ ansible_user }}/content/userconfig.txt
##################

## Now finally set set proxy for .asg network
if hostname -I | grep -qE '172.25.1[6789]' ; then
sudo sh -c 'cat << EOF > /etc/apt/apt.conf.d/95proxies
Acquire::http::Proxy "http://172.16.10.122:8888";
Acquire::https::Proxy "http://172.16.10.122:8888";
EOF'
fi
##################

## END PURPOSE SETUP ###########################################################
## Allow everybody to poweroff the machine
# echo "Allowing all users to poweroff and taking passwordless sudo away!"
# sudo chmod +s /sbin/shutdown
##################

## END SYSTEM SETTINGS #########################################################

## END INSTALLATION ############################################################
